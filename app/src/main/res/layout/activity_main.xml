<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dormant"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <View
        android:id="@+id/topGlow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:alpha="0.28"
        android:background="@drawable/ambient_glow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottomGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.18"
        android:background="@drawable/ambient_glow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/kicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:letterSpacing="0.28"
        android:text="@string/library_kicker"
        android:textAllCaps="true"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/libraryHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="serif"
        android:letterSpacing="0.12"
        android:text="@string/library_title"
        android:textColor="@android:color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kicker" />

    <TextView
        android:id="@+id/librarySubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/library_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/libraryHeader" />

    <LinearLayout
        android:id="@+id/stateRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/librarySubtitle">

        <com.google.android.material.chip.Chip
            android:id="@+id/stateBadge"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            app:chipCornerRadius="20dp" />

        <LinearLayout
            android:id="@+id/stateIndicators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/indicatorOne"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_indicator" />

            <View
                android:id="@+id/indicatorTwo"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_indicator" />

            <View
                android:id="@+id/indicatorThree"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_indicator" />

            <View
                android:id="@+id/indicatorFour"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_indicator" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="@color/image_frame_surface"
        app:cardCornerRadius="30dp"
        app:cardElevation="14dp"
        app:strokeColor="@color/image_frame_stroke"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/stateCard"
        app:layout_constraintDimensionRatio="4:3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stateRow">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/tomeImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="@string/tome_image_content_description"
                android:foreground="?attr/selectableItemBackground"
                android:scaleType="centerCrop" />

            <View
                android:id="@+id/edgeAura"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.32"
                android:background="@drawable/edge_aura" />

            <View
                android:id="@+id/imageScrim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/card_overlay_scrim" />

            <View
                android:id="@+id/ghostFlash"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:background="@drawable/ghost_flash_overlay" />

            <View
                android:id="@+id/shimmerSweep"
                android:layout_width="160dp"
                android:layout_height="match_parent"
                android:alpha="0"
                android:background="@drawable/shimmer_sweep"
                android:rotation="-12" />

            <TextView
                android:id="@+id/imageCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.18"
                android:text="@string/image_caption_default"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/stateCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/advanceStateButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/stateOverline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.22"
                android:text="@string/state_overline"
                android:textAllCaps="true"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/stateTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:textColor="@android:color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stateSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/ritualHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/ritual_hint"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/advanceStateButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/button_arcane"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minHeight="60dp"
        android:text="@string/advance_state"
        android:textAllCaps="false"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
