<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dormant"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <View
        android:id="@+id/topGlow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:alpha="0.28"
        android:background="@drawable/ambient_glow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottomGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.18"
        android:background="@drawable/ambient_glow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/kicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:letterSpacing="0.28"
        android:text="@string/library_kicker"
        android:textAllCaps="true"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/libraryHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="serif"
        android:letterSpacing="0.12"
        android:text="@string/library_title"
        android:textColor="@android:color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kicker" />

    <TextView
        android:id="@+id/librarySubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="@string/library_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/libraryHeader" />

    <LinearLayout
        android:id="@+id/stateRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/librarySubtitle">

        <com.google.android.material.chip.Chip
            android:id="@+id/stateBadge"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/black"
            app:chipCornerRadius="20dp" />

        <LinearLayout
            android:id="@+id/stateIndicators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/indicatorOne"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_indicator" />

            <View
                android:id="@+id/indicatorTwo"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_indicator" />

            <View
                android:id="@+id/indicatorThree"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_indicator" />

            <View
                android:id="@+id/indicatorFour"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_indicator" />
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/libraryStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="end"
            android:textColor="@color/text_hint"
            android:textSize="11sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/navigationCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:cardBackgroundColor="@color/nav_surface"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stateRow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/navRitualButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/nav_ritual"
                android:textAllCaps="false"
                app:cornerRadius="22dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/navLibraryButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/nav_library"
                android:textAllCaps="false"
                app:cornerRadius="22dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/navVaultButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/nav_vault"
                android:textAllCaps="false"
                app:cornerRadius="22dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/panelHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/advanceStateButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/navigationCard">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/ritualPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/imageCard"
                    android:layout_width="match_parent"
                    android:layout_height="258dp"
                    app:cardBackgroundColor="@color/image_frame_surface"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="14dp"
                    app:strokeColor="@color/image_frame_stroke"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/tomeImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/tome_image_content_description"
                            android:foreground="?attr/selectableItemBackground"
                            android:scaleType="centerCrop" />

                        <View
                            android:id="@+id/edgeAura"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.32"
                            android:background="@drawable/edge_aura" />

                        <View
                            android:id="@+id/imageScrim"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card_overlay_scrim" />

                        <View
                            android:id="@+id/ghostFlash"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0"
                            android:background="@drawable/ghost_flash_overlay" />

                        <View
                            android:id="@+id/shimmerSweep"
                            android:layout_width="160dp"
                            android:layout_height="match_parent"
                            android:alpha="0"
                            android:background="@drawable/shimmer_sweep"
                            android:rotation="-12" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:orientation="vertical"
                            android:paddingStart="20dp"
                            android:paddingTop="20dp"
                            android:paddingEnd="20dp"
                            android:paddingBottom="20dp">

                            <TextView
                                android:id="@+id/featuredGenre"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/button_arcane"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:textColor="@android:color/black"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/featuredTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:maxLines="2"
                                android:textColor="@android:color/white"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/featuredHook"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:maxLines="3"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/imageCaption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.18"
                                android:text="@string/image_caption_default"
                                android:textAllCaps="true"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/continueCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="10dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/continueOverline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.2"
                            android:text="@string/home_continue_overline"
                            android:textAllCaps="true"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/continueLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/continueMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <ProgressBar
                            android:id="@+id/continueProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="14dp"
                            android:max="100"
                            android:progress="35"
                            android:progressTint="@color/tome_stirring"
                            android:progressBackgroundTint="@color/card_stroke" />

                        <TextView
                            android:id="@+id/continueTimeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/text_hint"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/stateCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="10dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:id="@+id/stateOverline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.22"
                            android:text="@string/state_overline"
                            android:textAllCaps="true"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/stateTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="serif"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/stateSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:lineSpacingExtra="4dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/ritualHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/ritual_hint"
                            android:textColor="@color/text_hint"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/genreChipRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/forYouLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="serif"
                    android:text="@string/home_for_you"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/forYouRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="248dp"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingEnd="8dp" />

                <TextView
                    android:id="@+id/trendingLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="serif"
                    android:text="@string/home_trending"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/trendingRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="248dp"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingEnd="8dp" />

                <TextView
                    android:id="@+id/freshLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="serif"
                    android:text="@string/home_fresh_drops"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/freshRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="248dp"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingBottom="8dp"
                    android:paddingEnd="8dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/libraryPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/selectedTomeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/selectedTomeOverline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.22"
                        android:text="@string/library_selected_overline"
                        android:textAllCaps="true"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/selectedTomeTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/selectedTomeMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/selectedTomeHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/text_hint"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/libraryShelfLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.18"
                android:text="@string/library_shelf_label"
                android:textAllCaps="true"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bookRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="16dp" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/vaultPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/vaultDeckCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="10dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:id="@+id/vaultDeckOverline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.22"
                            android:text="@string/vault_deck_overline"
                            android:textAllCaps="true"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/vaultDeckTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/vault_deck_title"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/vaultDeckSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/vault_deck_subtitle"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/vaultDeckRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_marginTop="18dp"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:paddingEnd="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/vaultEconomyCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="10dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:id="@+id/vaultEconomyOverline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.22"
                            android:text="@string/vault_economy_overline"
                            android:textAllCaps="true"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/vaultInkValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/vaultTierCounts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/vaultFusionGuide"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:textColor="@color/text_hint"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/vaultArchivistCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="10dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:id="@+id/vaultArchivistOverline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.22"
                            android:text="@string/vault_archivist_overline"
                            android:textAllCaps="true"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/vaultArchivistNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/advanceStateButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/button_arcane"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minHeight="60dp"
        android:text="@string/advance_state"
        android:textAllCaps="false"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
