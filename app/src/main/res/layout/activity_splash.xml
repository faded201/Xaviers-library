<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dormant">

    <View
        android:id="@+id/topGlow"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:alpha="0.24"
        android:background="@drawable/ambient_glow"
        android:backgroundTint="@color/tome_stirring"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottomGlow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:alpha="0.14"
        android:background="@drawable/ambient_glow"
        android:backgroundTint="@color/tome_awakened"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/splashKicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:fontFamily="monospace"
        android:letterSpacing="0.22"
        android:text="@string/splash_kicker"
        android:textAllCaps="true"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/wordmarkWrap"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        app:layout_constraintBottom_toTopOf="@id/splashSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.54">

        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/splash_title_plate"
            android:minHeight="238dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/splashSigil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:shadowColor="#66000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="10"
                android:text="✦"
                android:textColor="@color/tome_stirring"
                android:textSize="34sp" />

            <TextView
                android:id="@+id/splashTitleTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="serif"
                android:letterSpacing="0.24"
                android:shadowColor="#8C000000"
                android:shadowDx="0"
                android:shadowDy="6"
                android:shadowRadius="16"
                android:text="@string/splash_title_line_one"
                android:textColor="@android:color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/splashTitleBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:letterSpacing="0.28"
                android:shadowColor="#8C031015"
                android:shadowDx="0"
                android:shadowDy="8"
                android:shadowRadius="18"
                android:text="@string/splash_title_line_two"
                android:textColor="@color/tome_awakened"
                android:textSize="42sp"
                android:textStyle="bold" />

            <View
                android:layout_width="116dp"
                android:layout_height="2dp"
                android:layout_marginTop="14dp"
                android:alpha="0.72"
                android:background="@color/tome_stirring" />

            <TextView
                android:id="@+id/splashTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:lineSpacingExtra="2dp"
                android:text="@string/splash_tagline"
                android:textAllCaps="true"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/splashSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginEnd="36dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="@string/splash_subtitle"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/wordmarkWrap"
        app:layout_constraintVertical_bias="0.12" />

</androidx.constraintlayout.widget.ConstraintLayout>
