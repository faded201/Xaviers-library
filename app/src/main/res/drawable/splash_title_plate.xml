<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="270"
                android:centerColor="#17100C"
                android:endColor="#0B1013"
                android:startColor="#25170E" />
            <stroke
                android:width="1dp"
                android:color="#30FFFFFF" />
        </shape>
    </item>

    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="29dp" />
            <stroke
                android:width="1dp"
                android:color="#3CF2B544" />
        </shape>
    </item>

    <item
        android:bottom="14dp"
        android:left="22dp"
        android:right="22dp"
        android:top="14dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="0"
                android:endColor="#04000000"
                android:startColor="#12FFFFFF" />
        </shape>
    </item>
</layer-list>
